# butterfly-effect Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=butterfly_dev

# PostgreSQL Relational Database
POSTGRES_URL=postgresql+asyncpg://butterfly:butterfly@localhost:5432/butterfly
POSTGRES_USER=butterfly
POSTGRES_PASSWORD=butterfly
POSTGRES_DB=butterfly

# Redis Cache & Message Broker
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# EXTERNAL DATA API KEYS
# ============================================================================

# FRED (Federal Reserve Economic Data) — Free tier
# Get key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# NewsAPI — $50/mo for production, free tier available
# Get key at: https://newsapi.org
NEWS_API_KEY=

# GDELT & SEC EDGAR require no API key (public data)

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Debug mode (set to false in production)
DEBUG=true

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Secret key for JWT/session signing (change in production)
SECRET_KEY=dev-secret-key-change-in-prod

# ============================================================================
# SIMULATION CONFIGURATION
# ============================================================================

# Maximum number of agents in a single simulation
MAX_AGENTS=500

# Simulation timeout in seconds
SIMULATION_TIMEOUT_SECONDS=300

# Maximum number of parallel simulations allowed
MAX_PARALLEL_SIMULATIONS=3

# ============================================================================
# CELERY CONFIGURATION
# ============================================================================

# Celery broker URL (same as Redis)
CELERY_BROKER_URL=redis://localhost:6379/0

# Celery result backend
CELERY_RESULT_BACKEND=redis://localhost:6379/1
